---
import MainLayout from "../layouts/MainLayout.astro";
import HeroSection from "../components/Device/HeroSection.astro";
import AlarmSection from "../components/Device/AlarmSection.astro";
import ProductSection from "../components/Device/ProductSection.astro";
import AppDownload from "../components/AppSection/AppDownload.astro";
import { contentData, stores } from "../components/constants/app";
import HowItWorks from "../components/Device/HowItWorks.astro";
import CTA from "../components/NewHome/CTA.astro";
import { ctaSection } from "../components/constants/newHome";
import FAQs from "../components/Device/FAQs.astro";
import {
  heroContent,
  features,
  alarmHeader,
  tabsData,
  sections,
  featureAssets,
  steps,
  header,
  faqsData,
} from "../components/constants/device";

const metaTitle = "EyEagle | Keeping You Safe, Wherever You Are";
const metaDesc =
  "From bathroom fall prevention to real-time emergency response — EyEagle is a complete safety system for families and groups who look out for each other.";
---

<MainLayout title={metaTitle} desc={metaDesc}>
  <HeroSection heroContent={heroContent} features={features} />
  <AlarmSection tabsData={tabsData} alarmHeader={alarmHeader} />
  <ProductSection sections={sections} featureAssets={featureAssets} />
  <HowItWorks steps={steps} header={header} />
  <FAQs faqsData={faqsData} />
  <AppDownload contentData={contentData} stores={stores} />
  <CTA ctaSection={ctaSection} />
</MainLayout>
