---
import MainLayout from "../layouts/MainLayout.astro";
import HeaderSection from "../components/AboutUs/HeaderSection.astro";
import FoundersSection from "../components/AboutUs/FoundersSection.astro";
import BannerSection from "../components/AboutUs/BannerSection.astro";
import CoreValues from "../components/AboutUs/CoreValues.astro";
import Explanation from "../components/AboutUs/Explanation.astro";
import CTA from "../components/NewHome/CTA.astro";
import { ctaSection } from "../components/constants/newHome";
import Blogs from "../components/Home/Blogs.astro";
import { blogsData } from "../components/constants/home";

const metaTitle = "About EyEagle | Safer, More Independent Living";
const metaDesc =
  "Meet the people and purpose behind EyEagle, founded to help older adults live more safely and independently at home.";
---

<MainLayout title={metaTitle} desc={metaDesc} schemaType="AboutPage">
  <HeaderSection />
  <BannerSection />
  <CoreValues />
  <Explanation />
  <FoundersSection />
  <Blogs blogsData={blogsData} showSeeMoreButton={true} />
  <CTA ctaSection={ctaSection} />
</MainLayout>
