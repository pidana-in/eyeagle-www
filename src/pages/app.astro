---
import MainLayout from "../layouts/MainLayout.astro";
import HeroSection from "../components/AppSection/HeroSection.astro";
import {
  HeroSectionData,
  heroTitle,
  heroDescription,
  features,
  featureData,
  backupSection,
  chapterSection,
  testimonials,
  nestSection,
  contentData,
  stores,
} from "../components/constants/app";
import Campus from "../components/AppSection/Campus.astro";
import Feature from "../components/AppSection/Feature.astro";
import Testimonials from "../components/AppSection/Testimonials.astro";
import NewChapter from "../components/AppSection/NewChapter.astro";
import AppDownload from "../components/AppSection/AppDownload.astro";
import BackupSection from "../components/AppSection/BackupSection.astro";
const metaTitle = "Advanced Elderly Fall Alert Devices - EyEagle Solutions";
const metaDesc =
  "Explore EyEagle’s innovative solutions for elderly safety. From fall alert devices to emergency alarm systems, protect your loved ones today.";
---

<MainLayout title={metaTitle} desc={metaDesc}>
  <HeroSection
    HeroSectionData={HeroSectionData}
    heroTitle={heroTitle}
    heroDescription={heroDescription}
  />
  <Campus nestSection={nestSection} />
  <Feature features={features} featureData={featureData} />
  <BackupSection backupSection={backupSection} />
  <NewChapter
    chapterSection={chapterSection}
    HeroSectionData={HeroSectionData}
  />
  <Testimonials testimonials={testimonials} />
  <!-- <Family
    sectionContent={sectionContent}
    FamilySection={FamilySection}
    familyCard={familyCard}
  /> -->
  <!-- <Membership membershipContent={membershipContent} plans={plans} /> -->
  <AppDownload contentData={contentData} stores={stores} />
</MainLayout>
