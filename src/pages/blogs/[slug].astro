---
export const prerender = true;

import { getCollection, render } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import { Image } from "astro:assets";
import { blogsData } from "../../components/constants/home";

export async function getStaticPaths() {
  const blogs = await getCollection("blogs");

  return blogs.map((blog) => ({
    params: {
      slug: blog.id,
    },
  }));
}

const { slug } = Astro.params;

const blogs = await getCollection("blogs");

const blog = blogs.find((b) => b.id === slug);

if (!blog) {
  throw new Error("Blog not found");
}

const { Content } = await render(blog);

const blogMeta = blogsData.find((item) => item.slug === blog.data.slug);

const metaTitle = blogMeta?.title ?? blog.data.title;

const metaDesc = blogMeta?.desc ?? "Read the latest article on EyEagle's blog.";

const site = (Astro.site?.toString() || "https://eyeagle.ai").replace(
  /\/+$/,
  "",
);

const metaImage = blogMeta?.img
  ? `${site}${blogMeta.img.src}`
  : blog.data.img
    ? `${site}${blog.data.img.src}`
    : "";

const availableBlogs = blogs.filter((b) => b.data.slug !== blog.data.slug);

for (let i = availableBlogs.length - 1; i > 0; i--) {
  const j = Math.floor(Math.random() * (i + 1));
  [availableBlogs[i], availableBlogs[j]] = [
    availableBlogs[j],
    availableBlogs[i],
  ];
}

const relatedBlogs = availableBlogs.slice(0, 3);
---

<MainLayout title={metaTitle} desc={metaDesc} metaImage={metaImage}>
  <style is:global>
    .prose ul ul {
      list-style-type: circle;
    }
  </style>

  <section class="bg-[#FFFFFF] lg:pt-44 pt-12 px-6 lg:px-40 w-full">
    <div
      class="lg:max-w-7xl w-full mx-auto grid grid-cols-1 md:grid-cols-2 items-center gap-8"
    >
      <div>
        <div class="flex flex-1 items-center gap-4">
          <a
            href="/blog"
            class="inline-flex items-center text-sm font-medium bg-[#FBEBEB] text-[#CC0000] rounded-full px-3 py-2 hover:bg-[#ebcaca] transition"
          >
            BLOG
          </a>

          <p class="text-sm text-[#737373] font-medium">
            {
              new Date(blog.data.date).toLocaleDateString("en-US", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })
            }
          </p>
        </div>
        <h1
          class="text-4xl lg:text-5xl font-semibold mt-6 mb-4 lg:leading-[54px]"
        >
          {blog.data.title}
        </h1>
        <div class="mt-6 flex items-center gap-3">
          <img
            src=""
            alt={blog.data.author}
            class="w-10 h-10 rounded-full object-cover bg-[#CC0000]"
          />
          <p class="text-sm font-medium text-[#525252]">
            {blog.data.author}
          </p>
        </div>
      </div>
      <div class="flex justify-center">
        <Image
          src={blog.data.img}
          alt={blog.data.title}
          class="max-h-80 w-auto rounded-2xl"
        />
      </div>
    </div>
    <div class="flex justify-center mt-20">
      <img src="/src/assets/Blog/Divider.png" alt="divider" />
    </div>
  </section>

  <article class="px-6 md:px-10 lg:px-40 pt-16 lg:pt-20">
    <div
      class="mx-auto flex flex-col lg:flex-row gap-12 lg:gap-20 place-content-between"
    >
      <!-- TOC -->
      <aside class="hidden lg:block w-[280px] shrink-0">
        <div class="rounded-[22px] border border-[#F5DADA] bg-[#FBEBEB] p-6">
          <h3 class="text-sm font-semibold uppercase text-[#CC0000] mb-4">
            In This Article
          </h3>

          <nav id="toc" class="space-y-3 text-sm text-[#525252]"></nav>
        </div>

        <div class="flex items-center gap-4 mt-6">
          <!-- Social icons -->
        </div>
      </aside>

      <!-- Blog Content -->
      <div
        id="blog-content"
        class="prose prose-lg max-w-[760px]
        prose-li:marker:text-[#111827]
        prose-h2:scroll-mt-24 prose-h3:scroll-mt-24
        prose-h1:text-2xl lg:prose-h1:text-5xl prose-h2:text-xl
        prose-h3:text-lg lg:prose-h3:text-3xl lg:prose-h2:text-4xl
        prose-h1:leading-tight lg:prose-h1:leading-[1.2]
        prose-h2:leading-snug lg:prose-h2:leading-normal
        prose-h1:font-semibold prose-h2:font-semibold prose-h3:font-semibold
        prose-h3:leading-snug lg:prose-h3:leading-normal"
      >
        <Content />
      </div>
    </div>
  </article>

  <!-- CTA -->
  <div class="mt-20 px-[120px]">
    <div
      class="rounded-[32px] bg-[#CC0000] px-10 py-10 flex flex-col lg:flex-row lg:items-center lg:justify-between gap-8"
    >
      <div class="">
        <p class="text-sm uppercase tracking-wide text-white mb-4">Next Step</p>
        <h2
          class="text-white text-3xl font-semibold leading-tight mb-4 max-w-[520px]"
        >
          Make every step safer before a fall happens.
        </h2>
        <p class="text-white/90 max-w-[640px]">
          EyEagle helps families move from worry to a practical home safety
          plan, with support that fits real rooms and real routines.
        </p>
      </div>
      <a
        href="/contact"
        class="inline-flex items-center justify-center rounded-full bg-white text-[#262626] px-8 py-4 font-medium hover:bg-gray-100"
      >
        Get bathroom assessment
      </a>
    </div>
  </div>

  <!-- Related Reading -->
  <div class="not-prose my-20 mx-[120px]">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-4xl font-semibold text-[#262626]">Related reading</h2>
      <a
        href="/blog"
        class="text-[#CC0000] text-sm font-medium uppercase hover:underline"
      >
        View All
      </a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        relatedBlogs.map((item) => (
          <a
            href={`/blogs/${item.data.slug}`}
            class="block rounded-3xl border border-[#E5E5E5] p-6 transition-all duration-300 hover:shadow-md"
          >
            <p class="text-[#CC0000] text-sm uppercase font-medium mb-5">
              Insights
            </p>
            <h3 class="text-xl font-semibold text-[#262626] leading-snug mb-4 line-clamp-2">
              {item.data.title}
            </h3>
            <p class="text-[#525252] leading-7 line-clamp-2">
              {item.data.desc}
            </p>
          </a>
        ))
      }
    </div>
  </div>
</MainLayout>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const article = document.getElementById("blog-content");
    const toc = document.getElementById("toc");

    if (!article || !toc) return;

    // Only include headings
    const headings = article.querySelectorAll("h2");

    headings.forEach((heading, index) => {
      if (!heading.id) {
        heading.id = `heading-${index + 1}`;
      }

      const link = document.createElement("a");
      link.href = `#${heading.id}`;
      link.textContent = heading.textContent;

      link.className =
        "block text-[16px] leading-7 text-[#525252] hover:text-[#CC0000]";

      toc.appendChild(link);
    });
  });
</script>
