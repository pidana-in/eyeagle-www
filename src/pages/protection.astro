---
import MainLayout from "../layouts/MainLayout.astro";
import HeroSection from "../components/Protection/HeroSection.astro";
import KitSection from "../components/Protection/KitSection.astro";
import WhereWeInstall from "../components/Protection/WhereWeInstall.astro";
import DesignedFor from "../components/Protection/DesignedFor.astro";
import Benefits from "../components/Protection/Benefits.astro";
import Installation from "../components/Protection/Installation.astro";
import Comparison from "../components/Protection/Comparison.astro";
import {
  featurePoints,
  heroContent,
  overviewCards,
  barFeatures,
  matFeatures,
  tapeFeatures,
  sectionHeaders,
  kitData,
  zones,
  installData,
  statsData,
  userCards,
  cardsData,
  installSteps,
  installFeatures,
  installCards,
  installImages,
  comparisonData,
  comparisonRows,
  comparisonColumns,
  ctaImage,
  ctaData,
  ctaContent,
  faqsData,
} from "../components/constants/protection";
import CTA from "../components/NewHome/CTA.astro";
import { ctaSection } from "../components/constants/newHome";
import FAQs from "../components/Protection/FAQs.astro";

const metaTitle = "EyEagle | Keeping You Safe, Wherever You Are";
const metaDesc =
  "From bathroom fall prevention to real-time emergency response — EyEagle is a complete safety system for families and groups who look out for each other.";
---

<MainLayout title={metaTitle} desc={metaDesc}>
  <HeroSection featurePoints={featurePoints} heroContent={heroContent} />
  <KitSection
    overviewCards={overviewCards}
    barFeatures={barFeatures}
    matFeatures={matFeatures}
    tapeFeatures={tapeFeatures}
    sectionHeaders={sectionHeaders}
    kitData={kitData}
  />
  <WhereWeInstall zones={zones} installData={installData} />
  <DesignedFor userCards={userCards} statsData={statsData} />
  <Benefits cardsData={cardsData} />
  <Installation
    installSteps={installSteps}
    installCards={installCards}
    installFeatures={installFeatures}
    installImages={installImages}
  />
  <Comparison
    comparisonData={comparisonData}
    comparisonRows={comparisonRows}
    comparisonColumns={comparisonColumns}
  />
  <FAQs faqsData={faqsData} />
  <CTA ctaSection={ctaSection} />
</MainLayout>
