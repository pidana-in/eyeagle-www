---
import HeroSection from "../components/Manifesto/HeroSection.astro";
import BannerSection1 from "../components/Manifesto/BannerSection1.astro";
import ContextSection from "../components/Manifesto/ContextSection.astro";
import BannerSection2 from "../components/Manifesto/BannerSection2.astro";
import BottomContextsSection from "../components/Manifesto/BottomSection.astro";
import MainLayout from "../layouts/MainLayout.astro";
import DesireSection from "../components/Home/DesireSection.astro";
import desireImage from "../assets/Navbar/desireImage.png";
import {descriptionButton,desireSection1} from "../components/constants/home";
import WorldSafety from "../components/Manifesto/WorldSafety.astro";
import Benifits from "../components/Manifesto/Benifits.astro";
import Blogs from "../components/Home/Blogs.astro";
import { blogsData } from "../components/constants/home";

const metaTitle = "EyEagle | Keeping You Safe, Wherever You Are";
const metaDesc =
  "From bathroom fall prevention to real-time emergency response — EyEagle is a complete safety system for families and groups who look out for each other.";
---

<MainLayout title={metaTitle} desc={metaDesc}>
  <!-- <HeroSection /> -->
  <!-- <BannerSection1 /> -->
  <!-- <ContextSection /> -->
  <BottomContextsSection />
  <!-- <BannerSection2 /> -->
   <WorldSafety/>
   <Benifits/>
   <Blogs blogsData={blogsData} showSeeMoreButton={true} />
  <section class="w-full">
    <DesireSection item={desireImage} desireSection1={desireSection1} descriptionButton={descriptionButton} className="mt-0 bg-white"/>
  </section>
</MainLayout>