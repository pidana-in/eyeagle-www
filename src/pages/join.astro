---
export const prerender = false;

import MainLayout from "../layouts/MainLayout.astro";
import {
  WaitlistFormData,
  WaitlistHeaderData,
} from "../components/constants/waitlist";
import { URLS } from "../utils/urls";
import { countries } from "../components/constants/common";
import Icon from "../components/common/Icon.astro";
import { upsertShopifySubscriber } from "../server/shopify";
import nodemailer from "nodemailer";

const metaTitle = "Join Our Community for Elderly Safety Solutions – EyEagle";
const metaDesc =
  "Join EyEagle - Stay connected and ensure safety with our emergency alert devices for the elderly. Reliable, efficient, and easy to set up!";

const {
  SMTP_HOST: smtpHost,
  SMTP_USER: smtpUser,
  SMTP_PASS: smtpPassword,
  SMTP_FROM: smtpFrom,
  SMTP_TO: smtpTo,
  SMTP_PORT: smtpPort,
  USE_SHOPIFY_JOIN,
} = import.meta.env;

let formPosted = false;

if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();

    const fullName = String(formData.get("fullName") || "");
    const email = formData.get("userEmail");
    const countryCode = formData.get("phCode");
    const phoneNumber = formData.get("phoneNumber");
    const city = formData.get("userCity");
    const acceptance = formData.getAll("userAcceptCheck");

    const apiPayload = {
      name: `${fullName}`,
      countryCode,
      mobileNumber: phoneNumber,
      email,
      city,
      interests: acceptance,
      isNewsletterSubscribed: acceptance.length > 0,
    };

    const fetchResponse = await fetch(URLS.USER_WAITLIST_API, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(apiPayload),
    });

    const apiResult = await fetchResponse.json();

    const useShopify =
      String(USE_SHOPIFY_JOIN || "").toLowerCase() === "true" ||
      String(USE_SHOPIFY_JOIN || "") === "1";

    if (useShopify) {
      // Subscribe/create customer in Shopify with double opt-in when accepted
      try {
        if (acceptance.length > 0) {
          const fullPhone = `${countryCode || ""}${phoneNumber || ""}`.trim();
          const tags = ["waitlist", "source:join-page"]; // Adjust if you prefer different tags
          const subResult = await upsertShopifySubscriber({
            email: String(email),
            fullName: fullName || undefined,
            phone: fullPhone || undefined,
            tags,
          });
          if (!subResult.ok) {
            console.error("Shopify subscription error:", subResult.error);
          }
        }
      } catch (shopifyErr) {
        console.error("Error while calling Shopify:", shopifyErr);
      }
    } else {
      // Fallback to email notification via Nodemailer (original behavior)
      try {
        const transporter = nodemailer.createTransport({
          host: smtpHost,
          port: Number(smtpPort),
          secure: Number(smtpPort) === 465,
          auth: { user: smtpUser, pass: smtpPassword },
        });

        const emailContent = `\nNew Waitlist Registration:\n\nName: ${`${fullName}`.trim()}\nEmail: ${email}\nPhone: ${countryCode || ""}${phoneNumber || ""}\nCity: ${city}\nNewsletter: ${acceptance.length > 0 ? "Yes" : "No"}\n        `;

        const currentDate = new Date().toISOString().slice(0, 10);

        await transporter.sendMail({
          from: smtpFrom,
          to: smtpTo,
          subject: `New Waitlist Registration - ${currentDate}`,
          text: emailContent,
        });
      } catch (emailErr) {
        console.error("Error while sending email:", emailErr);
      }
    }

    if (apiResult?.status === "success") {
      Astro.response.status = 303;
      Astro.response.headers.set("Location", "/success");
    }
  } catch (error) {
    console.error("Error while submitting form:", error);
  }
}
---

<MainLayout title={metaTitle} desc={metaDesc}>
  <section class="bg-[#F6F4F2] font-sans-instrument">
    <section class="xl:container px-5 py-10 md:px-20 md:pt-32 md:pb-12">
      <div
        class="flex flex-col lg:flex-row justify-between items-center gap-10 lg:gap-28"
      >
        <div class="lg:w-1/2 text-center md:text-start">
          <h1
            class="text-3xl md:text-5xl font-semibold md:leading-15 mb-5 md:mb-8"
          >
            {WaitlistHeaderData.title}
          </h1>
          <p class="text-lg font-medium">{WaitlistHeaderData.description}</p>
        </div>
        <div class="lg:w-1/2 md:p-10 rounded-xl">
          <div id="joinForm" class={formPosted ? "hidden" : "block"}>
            <form method="POST" class="flex flex-col gap-5" id="waitlistForm">
              <div class="flex flex-col gap-3">
                <label for="fullNameField">Full Name*</label>
                <input
                  id="fullNameField"
                  type="text"
                  name="fullName"
                  placeholder="Enter Name"
                  required
                  class="w-full p-3 border border-[#9C9C9C] rounded-xl placeholder:text-[#666666] placeholder:text-base"
                />
                <p id="fullNameError" class="text-red-500 text-sm hidden">
                  Please enter a valid full name
                </p>
              </div>
              <div class="flex flex-col gap-3">
                <label for="phoneNumField">Phone number*</label>
                <div class="relative">
                  <button
                    type="button"
                    id="dropdownButton"
                    aria-label="Choose country calling code"
                    aria-controls="dropdownMenu"
                    aria-expanded="false"
                    class="absolute inset-y-0 left-0 bg-[#F6F6F6] px-2 text-[#666666] text-base border border-r-0 border-[#9C9C9C] rounded-l-xl flex items-center cursor-pointer"
                  >
                    <span class="flex items-center">
                      <Icon
                        iconName="keyboard_arrow_down"
                        classNames="hidden"
                      />
                    </span>
                    <div class="flex items-center gap-2"></div>
                  </button>
                  <input id="phCode" name="phCode" value="" class="hidden" />
                  <div
                    id="dropdownMenu"
                    role="listbox"
                    class="absolute mt-1 bg-white border border-gray-300 rounded-md shadow-md hidden text-black max-h-62.5 overflow-y-auto w-52 z-20"
                  >
                    {
                      countries
                        .sort((a, b) => a.code.localeCompare(b.code))
                        .map((country) => (
                          <button
                            type="button"
                            role="option"
                            class="w-full px-4 py-2 cursor-pointer hover:bg-gray-300 text-black flex items-center gap-2"
                            data-value={country.dial_code}
                            data-country-code={country.code}
                          >
                            <img
                              src={`https://flagcdn.com/w40/${country.code.toLowerCase()}.png`}
                              alt={`${country.code} flag`}
                              width="20"
                            />
                            {country.dial_code}
                          </button>
                        ))
                    }
                  </div>
                  <input
                    id="phoneNumField"
                    type="tel"
                    name="phoneNumber"
                    placeholder="Phone Number"
                    required
                    inputmode="numeric"
                    pattern="[6-9][0-9]{9}"
                    maxlength="10"
                    class="w-full p-3 border border-[#9C9C9C] rounded-xl placeholder:text-[#666666] placeholder:text-base"
                  />
                </div>
                <p id="phoneError" class="text-red-500 text-sm hidden">
                  Please enter a valid 10-digit mobile number
                </p>
              </div>
              <div class="flex flex-col gap-3">
                <label for="emailField">Email*</label>
                <input
                  id="emailField"
                  type="email"
                  name="userEmail"
                  placeholder="Enter Email"
                  required
                  class="w-full p-3 border border-[#9C9C9C] rounded-xl placeholder:text-[#666666]"
                />
              </div>
              <div class="flex flex-col gap-3">
                <label for="cityField">City*</label>
                <input
                  id="cityField"
                  type="text"
                  name="userCity"
                  placeholder="City Name"
                  required
                  class="w-full p-3 border border-[#9C9C9C] rounded-xl placeholder:text-[#666666]"
                />
              </div>
              <div class="mt-2">
                <p class="font-medium mb-3">Interest (Optional)</p>
                <div class="flex flex-col gap-2">
                  <label class="flex items-center gap-2">
                    <input
                      type="checkbox"
                      name="userAcceptCheck"
                      value="notify_launch"
                      class="h-4 w-4 border-gray-400"
                    />
                    <span class="text-[#2E2323]"
                      >{WaitlistFormData.notifyLaunch}</span
                    >
                  </label>
                  <label class="flex items-center gap-2">
                    <input
                      type="checkbox"
                      name="userAcceptCheck"
                      value="early_access"
                      class="h-4 w-4 border-gray-400"
                    />
                    <span class="text-[#2E2323]"
                      >{WaitlistFormData.earlyAccess}</span
                    >
                  </label>
                  <label class="flex items-center gap-2">
                    <input
                      type="checkbox"
                      name="userAcceptCheck"
                      value="talk_expert"
                      class="h-4 w-4 border-gray-400"
                    />
                    <span class="text-[#2E2323]"
                      >{WaitlistFormData.talkExpert}</span
                    >
                  </label>
                </div>
              </div>
              <button
                type="submit"
                id="submitButton"
                class="md:w-full p-4 rounded-[30px] text-white bg-primary font-medium mt-2 relative"
              >
                <span id="buttonText">{WaitlistFormData.buttonTitle}</span>
                <div
                  id="loader"
                  class="hidden absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2"
                >
                  <div class="spinner"></div>
                </div>
              </button>
              <p class="text-base text-center text-gray-600 mt-2">
                No payment now. We’ll only notify you when it’s available
              </p>
            </form>
          </div>
        </div>
      </div>
      <!-- <div class="pt-10">
        <h3
          class="font-semibold font-barlow text-[#212121] text-xl lg:text-[40px] lg:leading-[100%]"
        >
          <span class="text-primary">EyEagle</span> is built to keep your loved ones
          safe,
          <span class="relative z-0"
            >around the clock.
            <span
              class="absolute w-full h-2 bg-primary/40 lg:top-9 lg:right-0 top-4 left-0 -z-50"
            >
            </span>
          </span>
        </h3>
      </div> -->
      <!-- <div
        class="lg:py-20 pt-8 grid grid-cols-2 gap-4 md:grid-cols-4 lg:gap-8 justify-self-start"
      >
        {
          bathroomData?.map((item: { id: number }) => (
            <a href={`/#${scrollDataSection[item.id]}`}>
              <BathroomSection item={item} mobile={false} />
            </a>
          ))
        }
      </div> -->
    </section>
  </section>
</MainLayout>

<style>
  .spinner {
    width: 20px;
    height: 20px;
    border: 3px solid rgba(255, 255, 255, 0.3);
    border-radius: 50%;
    border-top-color: white;
    animation: spin 1s ease-in-out infinite;
  }

  .spinner-large {
    width: 48px;
    height: 48px;
    border: 4px solid rgba(204, 0, 0, 0.3);
    border-radius: 50%;
    border-top-color: #cc0000;
    animation: spin 1s ease-in-out infinite;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }
</style>

<script is:inline>
  const dropdownButton = document.getElementById("dropdownButton");
  const dropdownMenu = document.getElementById("dropdownMenu");
  const fullNameField = document.getElementById("fullNameField");
  const fullNameError = document.getElementById("fullNameError");
  const phCode = document.getElementById("phCode");
  const phoneNumField = document.getElementById("phoneNumField");
  const submitButton = document.getElementById("submitButton");
  const buttonText = document.getElementById("buttonText");
  const loader = document.getElementById("loader");

  const iconSpan = document.createElement("span");
  iconSpan.className = "text-base md:text-lg ml-2";
  iconSpan.setAttribute("aria-hidden", "true");
  iconSpan.textContent = "⌄";

  dropdownButton.addEventListener("click", () => {
    dropdownMenu.classList.toggle("hidden");
    dropdownButton.setAttribute(
      "aria-expanded",
      String(!dropdownMenu.classList.contains("hidden")),
    );
  });

  dropdownMenu.addEventListener("click", (event) => {
    const option = event.target instanceof Element
      ? event.target.closest("button[data-value][data-country-code]")
      : null;
    if (!(option instanceof HTMLButtonElement)) return;

    const selectedDialCode = option.dataset.value;
    const selectedCountryCode = option.dataset.countryCode;
    if (!selectedDialCode || !selectedCountryCode) return;

    dropdownButton.innerHTML = "";
    const flagImage = document.createElement("img");
    flagImage.src = `https://flagcdn.com/w40/${selectedCountryCode.toLowerCase()}.png`;
    flagImage.alt = `${selectedCountryCode} flag`;
    flagImage.width = 20;
    flagImage.className = "mr-2";

    dropdownButton.appendChild(flagImage);
    dropdownButton.appendChild(document.createTextNode(selectedDialCode));
    dropdownButton.appendChild(iconSpan);

    phCode.value = selectedDialCode;

    dropdownMenu.classList.add("hidden");
    dropdownButton.setAttribute("aria-expanded", "false");

    document
      .querySelectorAll("#dropdownMenu > button[data-value]")
      .forEach((el) => el.classList.remove("bg-gray-300"));
    option.classList.add("bg-gray-300");
  });

  document.addEventListener("click", (event) => {
    if (
      !dropdownButton.contains(event.target) &&
      !dropdownMenu.contains(event.target)
    ) {
      dropdownMenu.classList.add("hidden");
      dropdownButton.setAttribute("aria-expanded", "false");
    }
  });

  function initializeDefaultPhoneCode() {
    phoneNumField.classList.add("pl-[112px]");
    dropdownButton.classList.add("max-w-[105px]");

    const defaultDialCode = "+91";
    const defaultOption = Array.from(
      dropdownMenu.querySelectorAll("button[data-value][data-country-code]"),
    ).find((option) => option.dataset.value === defaultDialCode);

    if (defaultOption instanceof HTMLButtonElement) {
      const defaultCountryCode = defaultOption.dataset.countryCode;
      if (!defaultCountryCode) return;

      const flagImage = document.createElement("img");
      flagImage.src = `https://flagcdn.com/w40/${defaultCountryCode.toLowerCase()}.png`;
      flagImage.alt = `${defaultCountryCode} flag`;
      flagImage.width = 20;
      flagImage.className = "mr-2";

      dropdownButton.innerHTML = "";
      dropdownButton.appendChild(flagImage);
      dropdownButton.appendChild(document.createTextNode(defaultDialCode));
      dropdownButton.appendChild(iconSpan);

      phCode.value = defaultDialCode;
      defaultOption.classList.add("bg-gray-300");
    }
  }

  initializeDefaultPhoneCode();

  const phoneError = document.getElementById("phoneError");

  document
    .getElementById("waitlistForm")
    .addEventListener("submit", function (e) {
      const phoneValue = phoneNumField.value.trim();
      const phoneRegex = /^[6-9]\d{9}$/;

      const fullNameValue = fullNameField.value.trim();
      const nameRegex = /^[A-Za-z\s]{2,}$/;

      phoneError.classList.add("hidden");
      fullNameError.classList.add("hidden");

      phoneNumField.classList.remove("border-red-500");
      fullNameField.classList.remove("border-red-500");

      // FULL NAME VALIDATION
      if (!nameRegex.test(fullNameValue)) {
        e.preventDefault();
        fullNameError.classList.remove("hidden");
        fullNameField.classList.add("border-red-500");
        fullNameField.focus();
        return;
      }

      // PHONE VALIDATION
      if (!phoneRegex.test(phoneValue)) {
        e.preventDefault();
        phoneError.classList.remove("hidden");
        phoneNumField.classList.add("border-red-500");
        phoneNumField.focus();
        return;
      }

      buttonText.classList.add("opacity-0");
      loader.classList.remove("hidden");
      submitButton.disabled = true;
    });

  fullNameField.addEventListener("input", () => {
    fullNameError.classList.add("hidden");
    fullNameField.classList.remove("border-red-500");
  });

  phoneNumField.addEventListener("input", () => {
    phoneError.classList.add("hidden");
    phoneNumField.classList.remove("border-red-500");
  });
</script>
