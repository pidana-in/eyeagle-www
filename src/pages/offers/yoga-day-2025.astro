---
import MainLayout from "../../layouts/MainLayout.astro";
import Faqs from "../../components/Home/Faqs.astro";
import BathroomSection from "../../components/Home/BathroomSection.astro";
import { bathroomData } from "../../components/constants/home";
import Image from "../../components/common/OptimizedImage.astro";
import img from "../../assets/Home/Hero_17.png";
import Frame from "../../assets/Home/YogadayImage.png";
import Discount from "../../assets/Home/DiscountNew.png"
import FatherImage from "../../assets/Home/FatherImage.png";
import {descriptionButtonFathersday,FatherSection1,YogaSection2} from "../../components/constants/home";
import { scrollDataSection } from "../../components/constants/home";
import YogaSection from "../../components/Home/YogaSection.astro";
---

<MainLayout title="Expired International Yoga Day 2025 Offer | EyEagle" desc="This EyEagle International Yoga Day 2025 safety-kit offer has expired." noindex={true}>
  <section class="relative w-full min-h-110 sm:min-h-150 lg:min-h-300">
    <Image src={img} alt="hero image"  class="absolute inset-0 w-full h-full object-cover" />
    <div class="relative z-10 flex flex-col justify-center items-center text-center px-4 pt-10 lg:pt-20">
      <div class="absolute lg:top-40 top-10 font-sans-instrument">
        <h1 class="text-[#000000] lg:text-6xl sm:text-3xl text-xl font-semibold lg:leading-tight sm:leading-10 leading-7">
          Yoga se health,<span class="text-primary"> EyEagle se care</span><br />Dono saath ho, to bane perfect pair!
        </h1>
       <div class="lg:my-4.5 my-2 justify-center flex">
        <a href="https://payments.cashfree.com/forms/eyeagle-reserve-offer">
       <Image src={Discount} alt="Discount offer" class="w-[30%] mx-auto sm:w-30 lg:w-65" />
       </a>
       </div>
       
        <p class="lg:text-2xl sm:text-xl text-xs font-medium lg:my-12.5 mt-3 mb-4">Offer valid till June 21. Limited slots available.</p>
        <Image src={Frame} alt="FathersdayImage" class="absolute w-[70%] sm:w-[80%] lg:w-full left-1/2 transform -translate-x-1/2"/>
       </div>
    </div>
  </section>

  <section class="lg:py-30 pt-2 pb-6">
    
    <div class="font-barlow text-center lg:px-14 px-4">
        
      <p class="font-medium lg:text-[52px] lg:leading-tight text-lg text-[#000000] opacity-60 lg:mx-20 text-center">
       Yoga brings inner peace. EyEagle ensures outer safety. Together, they create harmony for your aging loved ones.
       This International Day of Yoga, let’s honour their strength with something deeper — protection.
        </p>
        <!-- <p class="font-medium lg:text-[52px] lg:leading-tight text-lg text-primary lg:mx-20">
         Prevent bathroom falls. Protect your parents.
      </p> -->
        <a href="https://payments.cashfree.com/forms/eyeagle-reserve-offer" class="bg-primary lg:py-3 lg:px-5 px-3 py-2 rounded-lg lg:my-17 my-6 inline-block lg:text-2xl text-sm font-semibold text-white">
          Book Now
        </a>
      <p class="lg:text-[40px] lg:leading-tight text-lg font-semibold"><span class="text-primary">EyEagle</span> is built to keep your loved ones safe, around the clock.</p>
    </div>

 <div class="lg:p-30 py-6 px-4 lg:container mt-8">
      <div
        class="grid grid-cols-2 gap-4 sm:grid-cols-4 lg:gap-8 justify-self-start"
      >
        {
          bathroomData?.map((item:{id:number}) => (
            <a href={`/#${scrollDataSection[item.id]}`}>
              <BathroomSection item={item} mobile={false} />
            </a>
          ))
        }
      </div>
    </div>
    <div class="text-[#000000] text-center font-sans-instrument mt-10">
   <p class="lg:text-5xl text-xl font-medium">Get 15% OFF on EyEagle Safety Kit + Free Safety Audit</p>
   <p class="lg:text-2xl text-sm font-medium mt-4 lg:mt-8 lg:mb-4">Offer valid till June 21. Limited slots available.</p>
     <div class="mt-5">
            <a href="https://payments.cashfree.com/forms/eyeagle-reserve-offer" class="bg-primary lg:py-3 lg:px-5 px-3 py-2 rounded-full inline-flex items-center lg:text-lg text-sm font-normal text-white">
              Book Now
              <span class="ml-2 text-sm" aria-hidden="true">→</span>
            </a>
          </div>
          </div>
          
  </section>

  <section class="bg-secondary">
    <Faqs />
    <YogaSection item={FatherImage} FatherSection1={FatherSection1} YogaSection2={YogaSection2} descriptionButtonFathersday={descriptionButtonFathersday}/>
  </section>
</MainLayout>

<script is:inline>
  const expiryDate = new Date("2025-06-21T23:59:59");
  const now = new Date();

  const isExpired = now > expiryDate;

  if (isExpired) {
    const links = document.querySelectorAll("a[href*='eyeagle-reserve-offer']");

    links.forEach((link) => {
      link.addEventListener("click", function (e) {
        e.preventDefault(); // prevent redirect
        showToast("This offer has expired. Stay tuned for upcoming deals.");
      });
    });
  }

  function showToast(message) {
    const toast = document.createElement("div");
    toast.textContent = message;
    toast.className =
      "fixed bottom-5 left-1/2 transform -translate-x-1/2 bg-white font-medium py-2 px-4 rounded-lg shadow-lg z-50 text-center";
    document.body.appendChild(toast);

    setTimeout(() => {
      toast.remove();
    }, 3000);
  }
</script>
