---
import Icon from "../common/Icon.astro";
import { EyeagleDiff } from "../constants/aboutus";
---

<section class="bg-[#F6F4F2] px-5 lg:px-[40px] py-20 lg:py-[200px]">
  <div class="xl:container">
    <p
      set:html={EyeagleDiff.title}
      class="text-[40px] text-center leading-[56px] lg:text-[48px] lg:font-bold font-medium lg:pb-[200px] pb-20"
    />
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-[40px] lg:px-8">
      {
        EyeagleDiff.content.map((content) => (
          <div class="flex flex-col gap-4 bg-white rounded-xl p-6">
            <Icon iconName={content.iconType} classNames="text-[#CC0000]" />
            <p class="leading-8 text-[20px] lg:text-[28px] font-semibold">
              {content.title}
            </p>
            <p class="leading-7 text-[18px] lg:text-base font-normal">
              {content.desc}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
