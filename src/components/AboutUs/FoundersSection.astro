---
import { aboutUsFoundersData } from "../constants/aboutus";
import Image from "../common/OptimizedImage.astro";
---
<section class="bg-white font-sans-instrument pb-20 px-5 lg:px-10 py-30">
  <div class="xl:container">
    <div class="w-full pb-12 lg:pb-25">
      <p class="text-primary font-medium text-center text-[18px] leading-5.25 mb-2">TEAM</p>
      <h2 class="font-semibold text-center text-[40px] lg:text-[68px] leading-11 lg:leading-19.5">The Minds<br /> Behind <span class="text-primary">EyEagle</span></h2>
    </div>
<div class="w-full flex flex-col gap-20 lg:flex-row justify-center items-center">
  {aboutUsFoundersData.map((founder) => (
    <div class="bg-[#ffffff] flex flex-col gap-5 h-full relative overflow-hidden group">
            <div class="relative bg-white m-auto rounded-xl">
        <Image
          src={founder.photo}
          alt={`${founder.name}'s Photo`}
          class="rounded-xl w-full h-full object-cover transition-all duration-300 group-hover:opacity-60"
        />
        <div 
  class="absolute inset-0 rounded-xl bg-linear-to-b from-[#CC0000] to-[#660000] flex items-center justify-center text-center p-5 opacity-0 pointer-events-none transition-all duration-300 group-hover:opacity-90 group-hover:pointer-events-auto md:opacity-0 md:pointer-events-none"
  data-speech-overlay
>
  <p class="font-medium text-base leading-7 text-white h-full flex items-center">
    {founder.speech}
  </p>

  <button 
    class="absolute top-3 right-3 text-white text-[24px] md:hidden"
    data-close-btn
  >
    ✖
  </button>
</div>
      </div>
      <div>
        <div class="grow flex flex-col">
          <h2 class="text-[20px] font-medium leading-6 text-[#000000]">{founder.name.toUpperCase()}</h2>
          <p class="font-medium leading-4.25 text-[16px] text-[#828282] mt-2">{founder.title}</p>
          <p class="font-medium leading-5 text-[14px] text-[#000000] mt-2">
            {founder.experience}
          </p>
        </div>
      </div>

    </div>
  ))}
</div>
    
</div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const overlays = document.querySelectorAll("[data-speech-overlay]");
    const closeButtons = document.querySelectorAll("[data-close-btn]");

    closeButtons.forEach((button, index) => {
      button.addEventListener("click", function () {        
        overlays[index].classList.add("hidden"); // Hide the speech overlay
      });
    });
  });
</script>
