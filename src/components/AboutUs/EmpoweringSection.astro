---
import empowering1 from "../../assets/Aboutus/empowering1.png"
import seniorCouple from "../../assets/Aboutus/senior-couple.png"
import empowering2 from "../../assets/Aboutus/empowering2.png"
import Image from "../common/OptimizedImage.astro";
---
<section class="relative font-sans-instrument h-auto lg:h-225 px-6 sm:px-10 lg:px-20 py-10 lg:py-25  xl:container">
  <div class="text-center lg:absolute lg:inset-x-0 lg:top-1/2 lg:left-1/2 lg:-translate-x-1/2 lg:-translate-y-1/2 z-10">
    <h2 class="text-[28px] sm:text-[40px] lg:text-[52px] max-w-121.25 mx-auto font-semibold">
      <span class="text-primary">Empowering</span> Seniors to Live Independently
    </h2>
    <p class="text-[16px] sm:text-[18px] max-w-121.25 mx-auto pt-6 text-gray-700">
      We believe that every older adult deserves to feel secure and confident in their own homes.
    </p>
  </div>
  
  <div class="grid grid-cols-2 lg:grid-cols-2 gap-6 lg:gap-x-125 place-items-center pt-20 lg:pt-0 z-0">
    <Image src={empowering1} class="w-35 sm:w-50 lg:w-73 lg:h-95.75 ml-0 lg:ml-25" alt="Empowering seniors" />
    <Image src={seniorCouple} class="w-50 sm:w-75 lg:w-107 lg:h-71.25" alt="Senior couple" />
    <Image src={empowering2} class="w-50 sm:w-75 lg:w-107 lg:h-71.25" alt="Empowering seniors" />
    <Image src={empowering1} class="w-35 sm:w-50 lg:w-73 lg:h-95.75 ml-0 lg:ml-30" alt="Empowering seniors" />
  </div>
</section>
