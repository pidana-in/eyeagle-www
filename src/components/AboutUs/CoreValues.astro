---
import { CoreValuesData } from "../constants/aboutus"
---
<section class="px-5 lg:px-20 py-20 lg:py-30 xl:container">
    <div>
        <p set:html={CoreValuesData.title} class="text-primary font-medium text-center text-[32px] lg:text-[52px] leading-11 lg:leading-18"></p>
        <p set:html={CoreValuesData.desc} class="text-black opacity-60 font-medium text-[28px] lg:text-[52px] lg:leading-18 py-8 lg:pt-5 text-center"></p>
    </div>
    <div>
<p set:html={CoreValuesData.coreTitle} class="text-center font-medium lg:font-bold text-[40px] lg:text-5xl leading-11 lg:leading-14 lg:mt-20 lg:mb-24 my-12"></p>
<div class="flex flex-col gap-10 ">
    {CoreValuesData.values.map((value,index)=>(
        <div class={`flex flex-col lg:flex-row justify-between items-center gap-5 border-b ${CoreValuesData.values?.length-1===index ? "border-none" : "pb-5 border-[#768087]"}`}>
            <div>
            <p class="leading-12 text-[32px] lg:text-[40px] font-medium lg:font-bold text-center opacity-90">{value.title}</p>
            </div>
            <div> 
            <p class="text-[18px] leading-7 lg:max-w-161.5 text-center lg:text-start font-normal">{value.desc}</p>
            </div>
        </div>
    ))}
</div>
    </div>
    </section>
