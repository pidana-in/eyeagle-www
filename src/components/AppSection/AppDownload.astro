---
import Image from "../common/OptimizedImage.astro";

const contentData = Astro.props.contentData;
const stores = Astro.props.stores;
---

<section class="2xl:container relative overflow-hidden">
  <!-- Background Ellipse -->
  <Image src={contentData.image} alt="CTA Image" class="absolute size-full" />
  <!-- Foreground Content -->
  <div
    class="flex flex-col px-5 items-center justify-center text-center relative z-10 py-40"
  >
    <div class="md:px-30">
      <h2 class="text-[28px] md:text-5xl font-bold leading-none tracking-wide">
        {contentData.title}
      </h2>
      <p
        class="md:text-lg text-base text-[#090D15] font-medium max-w-240 py-8"
      >
        {contentData.description}
      </p>
    </div>
    <!-- Store Buttons -->
    <div class="flex md:gap-5 px-5 items-center justify-center">
      {
        stores.map((store: any) => (
          <a href={store.href} target="_blank" rel="noopener noreferrer">
            <Image src={store.image} alt={store.alt} class="max-w-50" />
          </a>
        ))
      }
    </div>
  </div>
</section>
