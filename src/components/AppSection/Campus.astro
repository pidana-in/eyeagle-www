---
import Image from "../common/OptimizedImage.astro";

interface NestSection {
  title: {
    line1: string;
    red1: string;
    line2: string;
    red2: string;
  };
  description: string[];
  images: any[];
}

const nestSection = Astro.props.nestSection as NestSection;
---

<section class="w-full py-30 lg:py-24">
  <div>
    <!-- TOP -->
    <div class="grid lg:grid-cols-2 gap-10 xl:container px-4 lg:px-12">
      <!-- LEFT -->
      <h2
        class="text-[32px] leading-10 md:text-5xl font-bold md:leading-14"
      >
        {nestSection.title.line1}
        <br />
        <span class="text-primary">{nestSection.title.red1}</span>
        <br />
        {nestSection.title.line2}
        <br />
        <span class="text-primary">{nestSection.title.red2}</span>
      </h2>

      <!-- RIGHT -->
      <div class="text-base md:text-lg leading-7 space-y-10">
        {nestSection.description.map((text: string) => <p set:html={text} />)}
      </div>
    </div>

    <!-- CAROUSEL-->
    <div class="lg:mt-40 mt-20 overflow-hidden carousel flex justify-center">
      <div class="flex gap-6 w-max scroll-track">
        {
          [
            ...nestSection.images,
            ...nestSection.images,
            ...nestSection.images,
          ].map((img: any, i: number) => (
            <div class="w-55 md:w-[320px] lg:w-85 h-72.5 md:h-110 lg:h-114.5 shrink-0 rounded-[20px] overflow-hidden">
              <Image
                src={img}
                alt={`EyEagle family safety app screen ${(i % nestSection.images.length) + 1}`}
                class="w-full h-full object-cover"
              />
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scroll-track {
    animation: scroll 25s linear infinite;
    animation-play-state: paused; /* default = stopped */
  }

  .carousel:hover .scroll-track {
    animation-play-state: running; /* start on hover */
  }

  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-33.333%);
    }
  }
  .scroll-track {
    display: flex;
    gap: 24px;
    width: max-content;
    animation: scroll 25s linear infinite;
    animation-play-state: paused;
    will-change: transform;
  }
</style>
