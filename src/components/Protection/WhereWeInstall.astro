---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

type Zone = {
  image: ImageMetadata;
  title: string;
  subtitle: string;
  desc: string;
};
const zones: Zone[] = Astro.props.zones;
const installData = Astro.props.installData;
---

<section class="2xl:container mx-auto py-14 md:py-20 px-4 md:px-8 lg:px-16">
  <!-- Heading -->
  <div class="flex flex-col items-center text-center max-w-[900px] mx-auto">
    <h2 class="text-[32px] md:text-5xl font-bold leading-10 md:leading-[56px]">
      {installData.title}
    </h2>

    <p class="mt-5 text-base leading-[28px] max-w-[750px]">
      {installData.desc}
    </p>
  </div>
  <!-- Zones -->
  <div class="mt-12 md:mt-20 max-w-[1100px] mx-auto">
    {
      zones.map((zone: Zone, index: number) => (
        <div
          class={`flex flex-col md:flex-row items-center gap-6 md:gap-10
          rounded-3xl border bg-[#F9F7F7] overflow-hidden
          ${index !== 0 ? "mt-6 md:mt-8" : ""}`}
        >
          <Image
            src={zone.image}
            alt={zone.title}
            class="w-full md:w-[45%] h-auto object-cover"
          />
          <div class="px-5 md:px-0 py-6 md:py-10 md:w-[55%] md:max-w-[520px]">
            <h3 class="text-[#CC0000] text-xl font-bold">{zone.title}</h3>
            <p class="text-base mt-1">{zone.subtitle}</p>
            <p class="mt-3 text-base opacity-60 leading-7">{zone.desc}</p>
          </div>
        </div>
      ))
    }
    <p
      class="mt-16 md:mt-20 text-center text-base md:text-lg italic max-w-[700px] mx-auto"
    >
      {installData.footer}
    </p>
  </div>
</section>
