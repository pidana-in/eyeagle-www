---
import { Image } from "astro:assets";
const testimonialData = Astro.props.testimonialData;
---

<section class="container py-14 md:py-[120px]">
  <div class="mx-auto w-full max-w-7xl px-6 lg:px-8 text-center">
    <div class="max-w-[800px] mx-auto">
      <h2 class="text-2xl sm:text-3xl md:text-5xl font-bold text-neutral-800">
        {testimonialData.title}
      </h2>
      <p
        class="mt-5 md:mt-10 text-sm sm:text-base md:text-xl text-neutral-600 font-medium"
      >
        {testimonialData.subtitle}
      </p>
    </div>
    <div
      class="relative max-w-[960px] mx-auto mt-12 md:mt-[100px] px-10 md:px-16"
    >
      <!-- Left Arrow -->
      <button
        id="prev-btn"
        type="button"
        aria-label="Previous testimonial"
        class="absolute left-[-20px] lg:left-[-36px] xl:left-[-100px] top-[24%] -translate-y-1/2 text-[#CC0000] hover:text-[#a30000] transition-all duration-300 hover:scale-110"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-10 h-10 md:w-14 md:h-14"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M15 19l-7-7 7-7"></path>
        </svg>
      </button>
      <!-- Right Arrow -->
      <button
        id="next-btn"
        type="button"
        aria-label="Next testimonial"
        class="absolute right-[-20px] lg:right-[-36px] xl:right-[-100px] top-[24%] -translate-y-1/2 text-[#CC0000] hover:text-[#a30000] transition-all duration-300 hover:scale-110"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-10 h-10 md:w-14 md:h-14"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"
          ></path>
        </svg>
      </button>
      <span
        class="absolute left-0 top-0 text-[#CC0000] text-4xl sm:text-5xl md:text-7xl leading-none"
      >
        “
      </span>
      <span
        class="absolute right-0 bottom-28 text-[#CC0000] text-4xl sm:text-5xl md:text-7xl leading-none"
      >
        ”
      </span>
      <div id="testimonial-content">
        <p
          id="testimonial-quote"
          class="min-h-[180px] md:min-h-[220px] text-lg sm:text-xl md:text-[32px] leading-relaxed md:leading-10 text-neutral-800 font-medium"
        >
          {testimonialData.testimonials[0].quote}
        </p>
        <div class="mt-10 flex justify-center">
          <div
            class="w-20 h-20 md:w-24 md:h-24 rounded-full overflow-hidden shadow-lg"
          >
            <Image
              id="testimonial-image"
              src={testimonialData.testimonials[0].image}
              alt="testimonial"
              class="w-full h-full object-cover"
              loading="eager"
              fetchpriority="high"
            />
          </div>
        </div>
        <p
          id="testimonial-author"
          class="mt-4 md:mt-5 text-neutral-800 text-base md:text-lg font-medium italic"
        >
          {testimonialData.testimonials[0].author}
        </p>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ testimonials: testimonialData.testimonials }}>
  let current = 0;

  const quote = document.getElementById("testimonial-quote");
  const author = document.getElementById("testimonial-author");
  const image = document.getElementById("testimonial-image");

  function render(index) {
    quote.textContent = testimonials[index].quote;
    author.textContent = testimonials[index].author;
    image.src = testimonials[index].image.src;
  }

  document.getElementById("next-btn")?.addEventListener("click", () => {
    current = (current + 1) % testimonials.length;
    render(current);
  });

  document.getElementById("prev-btn")?.addEventListener("click", () => {
    current = (current - 1 + testimonials.length) % testimonials.length;
    render(current);
  });
</script>
