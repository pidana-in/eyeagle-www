---
import ResponsiveHeroImage from "../common/ResponsiveHeroImage.astro";
import type { ImageMetadata } from "astro";
import { SHOP_URLS } from "../../data/shop";

type HeroContent = {
  heading: string[];
  description: string;
  eyebrow: string;
};

type HeroData = {
  img1: ImageMetadata;
  img2: ImageMetadata;
};

interface Props {
  heroContent: HeroContent;
  heroData: HeroData;
}

const { heroContent, heroData } = Astro.props as Props;
---

<section class="py-12 md:py-16 lg:py-20">
  <div class="text-center">
    <div class="max-w-240 mx-auto px-4">
      <div
        class="inline-flex py-1.5 px-3 sm:py-2 sm:px-4 rounded-full bg-[#FBEBEB]"
      >
        <p class="text-primary text-sm sm:text-base md:text-lg font-bold">
          {heroContent.eyebrow}
        </p>
      </div>
      <h1
        class="mt-7 text-3xl sm:text-4xl md:text-6xl lg:text-7xl font-bold leading-tight md:leading-20"
      >
        {heroContent.heading[0]}{" "}
        <span class="text-primary">{heroContent.heading[1]}</span>{" "}
        {heroContent.heading[2]}{" "}
        <br class="md:hidden" />
        <span class="text-primary">{heroContent.heading[3]}</span>{" "}
        {heroContent.heading[4]}
      </h1>
      <p class="mt-4 md:mt-6 text-gray-600 text-base md:text-lg">
        {heroContent.description}
      </p>
    </div>
    <div class="mt-8 md:mt-14">
      <a
        href={SHOP_URLS.protectionKit}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex px-6 sm:px-10 md:px-14 py-3 md:py-4 text-base md:text-xl font-bold bg-primary text-white rounded-full"
      >
        Get EyEagle
      </a>
      <p class="text-gray-600 font-semibold mt-4 text-sm md:text-base">
        Make their home fall proof
      </p>
    </div>
  </div>
  <div class="mt-10 md:mt-16">
    <ResponsiveHeroImage
      desktop={heroData.img1}
      mobile={heroData.img2}
      alt="Elderly person fallen at home"
      class="w-full h-auto md:h-[65vh] object-cover"
      breakpoint={767}
    />
  </div>
</section>
