---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

type HeroContent = {
  heading: string[];
  description: string;
  eyebrow: string;
};

type HeroData = {
  img: ImageMetadata;
};

interface Props {
  heroContent: HeroContent;
  heroData: HeroData;
}

const { heroContent, heroData } = Astro.props as Props;
---

<section class="py-12 md:py-16 lg:pt-[200px] 2xl:container">
  <div class="mx-auto max-w-[1200px] text-center">
    <div class="max-w-[960px] mx-auto px-4">
      <div
        class="inline-flex py-1.5 px-3 sm:py-2 sm:px-4 rounded-full bg-[#FBEBEB]"
      >
        <p class="text-[#CC0000] text-sm sm:text-base md:text-lg font-bold">
          {heroContent.eyebrow}
        </p>
      </div>
      <h1
        class="mt-7 text-3xl sm:text-4xl md:text-6xl lg:text-7xl font-bold leading-tight md:leading-[80px]"
      >
        {heroContent.heading[0]}
        <span class="text-[#CC0000]">{heroContent.heading[1]}</span>
        {heroContent.heading[2]}
        <br class="md:hidden" />
        <span class="text-[#CC0000]">{heroContent.heading[3]}</span>
        {heroContent.heading[4]}
      </h1>
      <p class="mt-4 md:mt-6 text-gray-600 text-base md:text-lg">
        {heroContent.description}
      </p>
    </div>
    <div class="mt-8 md:mt-14">
      <a href="https://shop.eyeagle.ai/">
        <button
          class="px-6 sm:px-10 md:px-14 py-3 md:py-4 text-base md:text-xl font-bold bg-[#CC0000] text-white rounded-full"
        >
          Act Now
        </button>
      </a>
      <p class="text-gray-600 font-semibold mt-4 text-sm md:text-base">
        Make their home fall proof
      </p>
    </div>
  </div>
  <div class="mt-10 md:mt-16">
    <Image
      src={heroData.img}
      alt="Elderly person fallen at home"
      class="w-full h-auto object-cover"
      loading="eager"
    />
  </div>
</section>
