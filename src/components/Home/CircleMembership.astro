---
import Image from "../common/OptimizedImage.astro";
import { CircleMembershipData } from "../constants/home";
import appStore from "../../assets/Home/appStore.png";
import googleStore from "../../assets/Home/googleStore.png";
---

<section id="alerts" class="xl:container px-5 lg:px-20 pt-10 md:pt-30 pb-25 lg:pb-20 ">
<div class="pb-25 lg:pb-20">
    <h3 class="text-primary text-base lg:text-lg font-medium text-center">{CircleMembershipData.title}</h3>
    <h2 class="lg:max-w-340 font-medium text-[2.5rem] leading-11 lg:leading-18 lg:text-[3.75rem] m-auto mt-2 text-center ">{CircleMembershipData.subTItle1}</h2>
    <h2 class="lg:max-w-340 font-medium text-[2.5rem] leading-11 lg:leading-18 lg:text-[3.75rem] m-auto mt-2 text-center ">{CircleMembershipData.subTItle2}</h2>
</div>

<div class="pb-20">
    <h2 set:html={CircleMembershipData.midTitle} class="lg:max-w-280 font-medium text-[2rem] lg:text-4xl m-auto text-center leading-10 lg:leading-11"></h2>
    <p class="lg:max-w-280 m-auto mt-8 mb-8 font-normal text-lg text-center leading-7">{CircleMembershipData.desc}</p>
    <div class="md:flex grid grid-cols-1 w-full justify-center items-center h-12 gap-3">
    <a href="https://play.google.com/store/apps/details?id=com.app.eyeagle" target="_blank" rel="noopener noreferrer">
    <Image src={googleStore} alt={'googleStore'} class="w-full md:w-40.5 max-md:h-12 object-contain hover:cursor-pointer"/>
    </a>
    <a href="https://apps.apple.com/in/app/eyeagle/id6740724011" target="_blank" rel="noopener noreferrer">
    <Image src={appStore} alt={'appStore'} class="w-full md:w-36 max-md:h-12 object-contain hover:cursor-pointer"/>
    </a>
    </div>
</div>

<div>
    <Image src={CircleMembershipData.imgSrc} alt={"circleMembershipDataImg"} class={'max-md:hidden'}/>
    <Image src={CircleMembershipData.imgSrcMobile} alt={'circleMembershipDataImgMobile'} class={'md:hidden'}/>
</div>
</section>