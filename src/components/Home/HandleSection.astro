---
import Image from "../common/OptimizedImage.astro";
import { HandleSectionData } from "../constants/home";
---

<section id="installation" class="bg-white pt-15 pb-25 lg:py-30 px-5 lg:px-20 font-sans-instrument xl:container">
<div class="mb-25">
<p class="text-primary text-base lg:text-lg font-medium text-center">{HandleSectionData.title}</p>
<h2 class="lg:max-w-340 font-medium text-[2.5rem] leading-11 lg:leading-18 lg:text-[3.75rem] m-auto text-center ">{HandleSectionData.subTitle1}</h2>
<h2 class="lg:max-w-340 font-medium text-[2.5rem] leading-11 lg:leading-18 lg:text-[3.75rem] m-auto text-center ">{HandleSectionData.subTitle2}</h2>
</div>


    <div class="flex flex-col md:flex-row justify-center items-center gap-20 bg-[#F0F0F0] p-7.5 lg:p-15 rounded-2xl">
        <div class="flex flex-col gap-[1.438rem]">
            {HandleSectionData.instructions.map((inst,index)=>(
                <div class="flex flex-col gap-3">
                <h3 class="font-medium text-[1.25rem] leading-9.5 lg:text-3xl">{inst.title}</h3>
                <p class="text-lg font-normal leading-5.5 lg:leading-7">{inst.desc}</p>
                <div class={`h-px lg:mt-5 bg-[#D9D9D9] ${index===HandleSectionData.instructions.length-1 ? "hidden" : "block"}`}></div>
            </div>
        ))}
    </div>
    <div>
        <Image
        src={HandleSectionData.imgSrc}
        alt="emergencyBanner"
        />
    </div>
</div>
</section>