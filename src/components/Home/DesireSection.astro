---
import Image from "../common/OptimizedImage.astro";

const desireImage = Astro.props.item;
const className = Astro.props.className ?? '';
const desireSection1 = Astro.props.desireSection1;
const desireSection2 = Astro.props.desireSection2;
const descriptionButton = Astro.props.descriptionButton;
---

<section>
    <div class=`lg:py-30 lg:px-20 bg-secondary ${className}`>
      <div class="relative h-[20.438rem] overflow-hidden lg:h-225">
        <Image
          src={desireImage}
          alt="An older adult spending time with two young children"
          class="w-full h-full object-cover brightness-95 rounded-sm"
          style="height: 100%;"
        />
        <div class="w-full font-sans-instrument">
          <p class="xl:container xl:w-175 xl:right-145 xl:left-10 absolute lg:top-20 top-10 lg:left-20 left-5 lg:text-[4rem] text-2xl font-normal lg:leading-23 max-w-186 mx-auto  text-white">
            {desireSection1}
          </p>
          <p class="xl:container xl:w-175 xl:right-145 xl:left-10 absolute max-lg:top-28 top-67.5 max-lg:text-lg lg:max-w-2xl text-white lg:left-20 left-5">
            {desireSection2}
          </p>
          <a href="/join" class="xl:container xl:w-62.5 xl:right-255 xl:left-10 py-4 flex justify-between items-center w-48 text-white absolute top-56 lg:top-95 lg:left-20 left-5 px-8 lg:rounded-[99px] bg-primary rounded-full">
              <span>
                {descriptionButton}
              </span>
              <svg width="15" height="16" viewBox="0 0 15 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path fill-rule="evenodd" clip-rule="evenodd" d="M0.609375 8.76805H11.5822L6.5455 13.8048L7.80467 15.0639L15 7.86864L7.80467 0.67334L6.5455 1.93252L11.5822 6.96923H0.609375L0.609375 8.76805Z" fill="white"/>
              </svg>
          </a>
        </div>
      </div>
    </div>
</section>
