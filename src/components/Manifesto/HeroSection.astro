---
import { HeroSectionData } from "../constants/manifesto";
---

<section class="h-auto lg:h-164.25 border-2 font-sans-instrument bg-[#F6F4F2] lg:pt-29 pb-10 lg:p-0 ">
  <div class="mt-9 lg:mt-29 flex flex-col items-center justify-center px-4 xl:container">
    <button class="py-2 px-4 rounded-full font-medium text-primary text-[18px] lg:text-base">
      {HeroSectionData.btnText}
    </button>
    <h1 class="mt-2  text-[24px] lg:text-[72px] leading-8 lg:leading-23 text-center max-w-70 sm:max-w-90.25 lg:max-w-272.5 font-medium" set:html={HeroSectionData.title}>
    
    </h1>
    <p class="text-center text-black text-[18px] sm:text-lg mt-8 max-w-70 sm:max-w-180">
      {HeroSectionData.desc}
    </p>
  </div>
</section>
