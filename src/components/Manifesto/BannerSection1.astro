---
import Image from "../common/OptimizedImage.astro";
import manifestoBanner1 from "../../assets/Manifesto/manifesto_banner_1.png";
import { BannerSection1Data } from "../constants/manifesto";
---

<section class="relative h-100 font-sans-instrument sm:h-163.25 ">
  <Image src={manifestoBanner1} class="h-full w-full object-cover" alt="Manifesto Banner" />
  <div class="absolute inset-0 flex items-center justify-center sm:justify-start px-4 sm:px-10 xl:container">
    <h2 class="text-center sm:text-left text-white text-[24px] sm:text-[52px] leading-7 sm:leading-15 max-w-75 sm:max-w-156.75 p-4">
     {BannerSection1Data.title}
    </h2>
  </div>
</section>
