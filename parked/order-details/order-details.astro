---
import StatusCard from "../../src/components/common/StatusCard.astro";
import MainLayout from "../../src/layouts/MainLayout.astro";
import Tick from "../../src/assets/Common/Tick.png";
import OrderDetailsSection from "./components/OrderDetailsSection.astro";
import OrderFlow from "./components/OrderFlow.astro";
---

<MainLayout
  title="Order Details | EyEagle"
  desc="Review the delivery and installation status of your EyEagle order."
  noindex={true}
>
  <section>
    <StatusCard
      classNames="w-full px-6 py-5"
      img={Tick}
      imgClassNames="min-h-[2.25rem] min-w-[2.25rem]"
      title="Shipping address added"
      subTitle="We hope we are able to provide the right protection for your loved ones. In the next step, please tell us where the shipping needs to be done."
    />
  </section>

  <section class="bg-[#F6F4F2] md:p-0">
    <div class="flex xl:container flex-col md:flex-row-reverse">
      <OrderDetailsSection />
      <OrderFlow />
    </div>
  </section>
</MainLayout>
